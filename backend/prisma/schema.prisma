generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
  USER
}

enum PostType {
  BLOG
  RECIPE
}

enum EnrollmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum OrderStatus {
  PENDING
  AWAITING_CONFIRM
  CONFIRMED
  REJECTED
  CANCELLED
}

enum ProgramType {
  VIDEO_COURSE
  LIVE_CLASS
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  fullName  String
  role        Role         @default(USER)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  posts       Post[]
  enrollments Enrollment[]
  orders      Order[]
}
model Program {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  programType ProgramType @default(LIVE_CLASS)
  description String?
  price       Int?
  reviews     Int      @default(0)
  students    Int      @default(0)
  thumbnail     String?
  authorName    String?
  authorImage   String?
  learningGoals Json?
  classIncludes Json?
  curriculum    Json?
  premiumContent Json?
  isFeatured    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  chiefId       String?
  chief         Chief?   @relation(fields: [chiefId], references: [id])
  classSessions ClassSession[]
  orders        Order[]
  enrollments   Enrollment[]
}

model ClassSession {
  id                 String   @id @default(uuid())
  programId          String
  program            Program  @relation(fields: [programId], references: [id])
  startDate          DateTime?
  endDate            DateTime?
  enrollmentDeadline DateTime?
  dayOfWeek          String?
  timeRange          String?
  instructorOverride String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  enrollments        Enrollment[]
}

model Post {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  content     String
  desc        String?
  category    String?
  type        PostType @default(BLOG)
  thumbnail   String?
  authorId    String?
  authorName  String?
  dateIso     DateTime @default(now())
  dateString  String?
  author      User?    @relation(fields: [authorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Chief {
  id         String   @id @default(uuid())
  name       String
  role       String
  image      String?
  bio        String?
  biography  String?
  highlights String?
  skills     String?
  socialFb   String?
  socialTw   String?
  socialIn   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  programs   Program[]
}

model Testimonial {
  id        String   @id @default(uuid())
  excerpt   String
  text      String
  name      String
  role      String
  signature String?
  createdAt DateTime @default(now())
}

model Enrollment {
  id             String           @id @default(uuid())
  classSessionId String?
  userId         String?
  programId      String
  fullName       String
  email          String
  phone          String?
  status         EnrollmentStatus @default(PENDING)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  
  classSession   ClassSession?    @relation(fields: [classSessionId], references: [id])
  user           User?            @relation(fields: [userId], references: [id])
  program        Program          @relation(fields: [programId], references: [id])
}

model Contact {
  id        String   @id @default(uuid())
  fullName  String
  email     String
  subject   String?
  message   String
  createdAt DateTime @default(now())
}

model Order {
  id              String      @id @default(uuid())
  orderCode       String      @unique
  userId          String
  programId       String
  classSessionId  String?

  amount          Int
  transferContent String?

  proofImage      String?
  transactionRef  String?

  // Payment gateway fields (VNPay integration)
  paymentMethod          String?   // "MANUAL_BANK" | "VNPAY"
  paymentProvider        String?   // "VNPAY"
  paymentUrl             String?   // VNPay redirect URL (debug/audit)
  paymentInitiatedAt     DateTime?
  paymentExpiresAt       DateTime?
  gatewayTxnRef          String?   // maps to vnp_TxnRef (unique per payment attempt)
  gatewayTransactionNo   String?   // VNPay transaction number
  gatewayResponseCode    String?   // vnp_ResponseCode
  gatewayTransactionStatus String? // vnp_TransactionStatus
  paidAt                 DateTime?
  rawGatewayPayload      Json?     // verified callback payload

  status          OrderStatus @default(PENDING)
  adminNote       String?
  confirmedAt     DateTime?
  paidViaWebhook  Boolean     @default(false)

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user            User        @relation(fields: [userId], references: [id])
  program         Program     @relation(fields: [programId], references: [id])
}

model PaymentConfig {
  id              String   @id @default(uuid())
  bankName        String
  accountNumber   String
  accountHolder   String
  qrImage         String?
  transferNote    String?
  webhookSecret   String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
